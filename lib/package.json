{
    "name": "@ui5/webcomponents-vue",
    "version": "0.7.0",
    "description": "UI5 Web Components: webcomponents.vue",
    "type": "module",
    "author": "SAP SE (https://www.sap.com)",
    "license": "Apache-2.0",
    "keywords": [
        "openui5",
        "sapui5",
        "ui5",
        "vue",
        "vue3",
        "webcomponents"
    ],
    "main": "./dist/createComponent.js",
    "types": "./dist/createComponent.d.ts",
    "exports": {
        ".": {
            "types": "./dist/createComponent.d.ts",
            "default": "./dist/createComponent.js"
        },
        "./createComponent": {
            "types": "./dist/createComponent.d.ts",
            "default": "./dist/createComponent.js"
        },
        "./components": {
            "types": "./dist/components.d.ts",
            "default": "./dist/components.js"
        },
        "./dist/*.js": {
            "types": "./dist/*.d.ts",
            "default": "./dist/*.js"
        },
        "./src/*": "./src/*"
    },
    "scripts": {
        "start": "echo Building lib... && npm run build",
        "dev": "tsc --watch",
        "build": "tsc",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "peerDependencies": {
        "vue": "^3.5.27",
        "@ui5/webcomponents-base": "^2.19.0",
        "@ui5/webcomponents": "^2.19.0"
    },
    "peerDependenciesMeta": {
        "@ui5/webcomponents": {
            "optional": true
        }
    },
    "devDependencies": {
        "vue": "^3.5.27",
        "@ui5/webcomponents-base": "^2.19.0",
        "@ui5/webcomponents": "^2.19.0",
        "typescript": "^5.9.3",
        "eslint": "^9.0.0",
        "@eslint/js": "^9.0.0",
        "typescript-eslint": "^8.0.0",
        "vitest": "^4.0.0",
        "happy-dom": "^20.0.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/UI5/webcomponents-vue.git",
        "directory": "lib"
    },
    "engines": {
        "node": "^20.19.0 || >=22.12.0"
    }
}
